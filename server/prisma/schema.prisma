generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())

  name      String
  email     String   @unique
  password  String

  expenses  Expense[]
  budgets   Budget[]
  recurringExpenses RecurringExpense[]
  incomes   Income[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())

  title       String
  amount      Float

  category    String

  date        DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id        String   @id @default(uuid())

  amount    Float

  month     Int
  year      Int

  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id          String   @id @default(uuid())

  title       String
  amount      Float
  category    String

  frequency   String

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavingsGoal {
  id        String   @id @default(uuid())

  title     String
  target    Float
  saved     Float @default(0)

  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id          String   @id @default(uuid())

  title       String
  amount      Float

  source      String?

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
}