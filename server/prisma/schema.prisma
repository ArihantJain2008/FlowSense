generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())

  name      String
  email     String   @unique
  password  String
  themePreference String @default("system")
  currency String @default("INR")
  notificationSettings Json?

  expenses  Expense[]
  budgets   Budget[]
  recurringExpenses RecurringExpense[]
  incomes   Income[]
  savingsGoals SavingsGoal[]
  savingsAllocationBatches SavingsAllocationBatch[]
  categoryRules CategoryRule[]
  monthlySnapshots MonthlySnapshot[]
  expenseTemplates ExpenseTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())

  title       String
  amount      Float

  category    String
  merchant    String?
  note        String?
  paymentMethod String?
  isFavorite  Boolean @default(false)
  isRecurringGenerated Boolean @default(false)
  importConfidence Float?

  date        DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringExpenseId String?
  recurringExpense RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, isFavorite])
}

model Budget {
  id        String   @id @default(uuid())

  amount    Float

  month     Int
  year      Int

  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id          String   @id @default(uuid())

  title       String
  amount      Float
  category    String
  merchant    String?
  note        String?
  paymentMethod String?

  frequency   String
  startDate   DateTime @default(now())
  nextRunAt   DateTime @default(now())
  lastGeneratedAt DateTime?
  isActive    Boolean @default(true)
  dayOfMonth  Int?
  dayOfWeek   Int?

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedExpenses Expense[]
}

model SavingsGoal {
  id        String   @id @default(uuid())

  title     String
  target    Float
  saved     Float @default(0)
  monthlyContribution Float @default(0)
  targetDate DateTime?

  createdAt DateTime @default(now())

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations SavingsAllocation[]
}

model SavingsAllocationBatch {
  id             String   @id @default(uuid())
  month          Int
  year           Int
  totalAllocated Float
  createdAt      DateTime @default(now())

  userId         String
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations    SavingsAllocation[]

  @@unique([userId, month, year])
}

model SavingsAllocation {
  id        String   @id @default(uuid())
  amount    Float
  createdAt DateTime @default(now())

  goalId    String
  goal      SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  batchId   String
  batch     SavingsAllocationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Income {
  id          String   @id @default(uuid())

  title       String
  amount      Float

  source      String?
  note        String?
  merchant    String?
  paymentMethod String?
  isFavorite  Boolean @default(false)
  date        DateTime @default(now())

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, isFavorite])
}

model ExpenseTemplate {
  id          String   @id @default(uuid())
  name        String
  title       String
  amount      Float
  category    String
  merchant    String?
  note        String?
  paymentMethod String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model CategoryRule {
  id          String   @id @default(uuid())
  pattern     String
  normalizedMerchant String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pattern])
}

model MonthlySnapshot {
  id        String   @id @default(uuid())
  month     Int
  year      Int
  income    Float
  expenses  Float
  savings   Float
  budget    Float
  budgetUsage Float
  savingsRate Float
  largestExpenseTitle String?
  largestExpenseAmount Float?
  topCategory String?
  topCategoryAmount Float?
  comparisonIncome Float?
  comparisonExpenses Float?
  comparisonSavings Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}
